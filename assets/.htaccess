RewriteEngine On
Options +FollowSymLinks -MultiViews

# Cache hit: serve the file direct (no PHP, no signature re-check).
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^cache/.*\.(avif|webp|jpg|jpeg|png|gif)$ - [L]

# Cache miss: route to PHP shim, preserving query string (carries the HMAC `s`).
RewriteRule ^cache/(.+)$ _img/index.php?p=$1 [L,QSA]

# Long-lived caching for served variants. Includes immutable per RFC 8246.
<IfModule mod_headers.c>
    <FilesMatch "\.(avif|webp|jpg|jpeg|png|gif)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
